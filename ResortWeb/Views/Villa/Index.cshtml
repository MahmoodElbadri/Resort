@model IEnumerable<Villa>
@{
    ViewData["Title"] = "Index";
}

<div class="w-100 card border-0 p-4">
    <div class="card-header bg-success bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12">
                <h2 class="col-12 text-center text-white">Villa List</h2>
            </div>
        </div>
    </div>
    <div class="card-body border p-4">
        <div class="row pb-3">
            <div class="col-6 offset-6 pb-3 text-end">
                <a asp-controller="Villa" asp-action="Create" class="btn btn-secondary">
                    <i class="bi bi-cloud-plus"></i>  Create new Villa
                </a>
            </div>
            <table class="table table-bordered table-striped table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Square Feet</th>
                        <th>Occupancy</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var villa in Model)
                    {
                        <tr>
                            <!-- Villa Name with Icon -->
                            <td><i class="bi bi-house"></i> @villa.Name</td>

                            <!-- Price (formatted as currency) -->
                            <td>@villa.Price.ToString("C")</td>

                            <!-- Square Feet -->
                            <td>@villa.SqrFeet</td>

                            <!-- Occupancy -->
                            <td>@villa.Occupancy</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



