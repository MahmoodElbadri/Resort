@model VillaNumber
@{
    ViewData["Title"] = "Create Villa Number";
}


<div class="w-100 card border-0 p-4">
    <div class="card-header bg-success bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12">
                <h2 class="col-12 text-center text-white">Create a New Villa Number</h2>
            </div>
        </div>
    </div>
    <div class="card-body border p-4">
        <div class="row pb-3">
            <div class="card-body border p-4">
                <form method="post" asp-controller="VillaNumber" asp-action="Create" class="row">
                    <div class="p-3">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        @* <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.VillaNo" class="form-control border shadow" />
                            <label asp-for="@Model.VillaNo" class="form-label sm-2">Villa Number</label>
                            <span asp-validation-for="@Model.VillaNo" class="text-danger"></span>
                        </div> *@
                        <div class="form-floating py-2 col-12">
                            @* <input asp-for="@Model.VillaId" class="form-control border shadow" /> *@

                            <!--You can use it with ViewData-->
                            @* <select asp-for="@Model.VillaId" asp-items="@ViewData["Villas"] as List< SelectListItem>" class="form-select border shadow">
                                <option disabled selected>--Select Villa--</option>
                            </select> *@
                            <!--But I Prefer to use it with ViewBag it is more simple-->
                            <select asp-for="@Model.VillaId" asp-items="@ViewBag.Villas" class="form-select border shadow">
                                <option disabled selected>--Select Villa--</option>
                            </select>
                            <label asp-for="@Model.VillaId" class="form-label sm-2">Villa Id</label>
                            <span asp-validation-for="@Model.VillaId" class="text-danger"></span>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.SpecialDetails" class="form-control border shadow" />
                            <label asp-for="@Model.SpecialDetails" class="form-label sm-2">Villa Special Details</label>
                            <span asp-validation-for="@Model.SpecialDetails" class="text-danger"></span>
                        </div>
                        <div class="row pt-2">
                            <div class=" col-6 col-md-3">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-check-circle"></i>  Create
                                </button>
                            </div>
                            <div class="col-6 col-md-3">
                                <a asp-controller="VillaNumber" asp-action="Index" class="btn btn-danger w-100">
                                    <i class="bi bi-x-circle"></i>  Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}



