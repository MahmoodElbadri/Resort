@model Villa
@{
    ViewData["Title"] = "Create New Villa";
}

<div class="w-100 card border-0 p-4">
    <div class="card-header bg-success bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12">
                <h2 class="col-12 text-center text-white">Create a New Villa</h2>
            </div>
        </div>
    </div>
    <div class="card-body border p-4">
        <div class="row pb-3">
            <div class="col-6 offset-6 pb-3 text-end">
                <a asp-controller="Villa" asp-action="Create" class="btn btn-secondary">
                    <i class="bi bi-cloud-plus"></i>  Create new Villa
                </a>
            </div>
            <div class="card-body border p-4">
                <form method="post" asp-controller="Villa" asp-action="Create" class="row">
                    <div class="p-3">
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.Name" class="form-control border shadow" />
                            <label asp-for="@Model.Name" class="form-label sm-2">Villa Name</label>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>



