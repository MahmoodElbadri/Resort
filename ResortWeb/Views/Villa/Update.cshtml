@model Villa
@{
    ViewData["Title"] = "Update Villa";
}
<div class="w-100 card border-0 p-4">
    <div class="card-header bg-success bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12">
                <h2 class="col-12 text-center text-white">Update Villa</h2>
            </div>
        </div>
    </div>
    <div class="card-body border p-4">
        <div class="row pb-3">
            <div class="card-body border p-4">
                <form method="post" asp-controller="Villa" asp-action="Update" class="row">
                    <input type="hidden" asp-for="@Model.Id" value="@Model.Id" />   
                    <div class="p-3">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.Name" value="@Model.Name" class="form-control border shadow" />
                            <label asp-for="@Model.Name" class="form-label sm-2">Villa Name</label>
                            <span asp-validation-for="@Model.Name" class="text-danger"></span>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.Description" value="@Model.Description" class="form-control border shadow" />
                            <label asp-for="@Model.Description" class="form-label sm-2">Villa Description</label>
                            <span asp-validation-for="@Model.Description" class="text-danger"></span>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.Price" value="@Model.Price" class="form-control border shadow" />
                            <label asp-for="@Model.Price" class="form-label sm-2">Villa Price</label>
                            <span asp-validation-for="@Model.Price" class="text-danger"></span>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.SqrFeet" value="@Model.SqrFeet" class="form-control border shadow" />
                            <label asp-for="@Model.SqrFeet" class="form-label sm-2">Villa SQR Feet</label>
                            <span asp-validation-for="@Model.SqrFeet" class="text-danger"></span>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="@Model.Occupancy" value="@Model.Occupancy" class="form-control border shadow" />
                            <label asp-for="@Model.Occupancy" class="form-label sm-2">Villa Occupancy</label>
                            <span asp-validation-for="@Model.Occupancy" class="text-danger"></span>
                        </div><div class="form-floating py-2 col-12">
                            <input asp-for="@Model.ImageUrl" value="@Model.ImageUrl" class="form-control border shadow" />
                            <label asp-for="@Model.ImageUrl" class="form-label sm-2">Villa Image</label>
                            <span asp-validation-for="@Model.ImageUrl" class="text-danger"></span>
                        </div>
                        <div class="row pt-2">
                            <div class=" col-6 col-md-3">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-check-circle"></i>  Update
                                </button>
                            </div>
                            <div class="col-6 col-md-3">
                                <a asp-controller="Villa" asp-action="Index" class="btn btn-danger w-100">
                                    <i class="bi bi-x-circle"></i>  Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}



